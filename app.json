{
  "expo": {
    "name": "Plim",
    "slug": "plim-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "plim",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elizzeuscorp.plim",
      "infoPlist": {
        "NSCalendarsUsageDescription": "O Plim adiciona suas tarefas de rotina no seu calendário para você não esquecer.",
        "NSRemindersUsageDescription": "O Plim cria lembretes para suas tarefas de rotina."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F3FF"
      },
      "package": "com.elizzeuscorp.plim",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withGradleMemory",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C3AED",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "O Plim precisa acessar seu calendário para agendar suas tarefas."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4118b5d4-1ca6-41dd-8a36-88c7135a3da8"
      }
    }
  }
}
